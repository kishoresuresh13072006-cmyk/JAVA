import java.util.ArrayList;
import java.util.Scanner;

class Passenger {
    int passengerId;
    String name;
    int age;
    String source;
    String destination;

    Passenger(int passengerId, String name, int age,
              String source, String destination) {
        this.passengerId = passengerId;
        this.name = name;
        this.age = age;
        this.source = source;
        this.destination = destination;
    }

    void displayTicket() {
        System.out.println("\n===== TICKET DETAILS =====");
        System.out.println("Passenger ID : " + passengerId);
        System.out.println("Name         : " + name);
        System.out.println("Age          : " + age);
        System.out.println("Source       : " + source);
        System.out.println("Destination  : " + destination);
        System.out.println("--------------------------");
    }
}

public class Main {

    static ArrayList<Passenger> passengers = new ArrayList<>();
    static Scanner sc = new Scanner(System.in);
    static int availableSeats = 50;

    static void bookTicket() {
        if (availableSeats == 0) {
            System.out.println("Sorry! No seats available.");
            return;
        }

        System.out.print("Enter Passenger ID: ");
        int id = sc.nextInt();
        sc.nextLine();

        System.out.print("Enter Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Age: ");
        int age = sc.nextInt();
        sc.nextLine();

        System.out.print("Enter Source Station: ");
        String source = sc.nextLine();

        System.out.print("Enter Destination Station: ");
        String destination = sc.nextLine();

        Passenger p = new Passenger(id, name, age, source, destination);
        passengers.add(p);

        availableSeats--;

        System.out.println("Ticket Booked Successfully!");
        p.displayTicket();
    }

    static void viewReservations() {
        if (passengers.isEmpty()) {
            System.out.println("No Reservations Found!");
            return;
        }

        for (Passenger p : passengers) {
            p.displayTicket();
        }
    }

    static void searchTicket() {
        System.out.print("Enter Passenger ID: ");
        int id = sc.nextInt();

        for (Passenger p : passengers) {
            if (p.passengerId == id) {
                p.displayTicket();
                return;
            }
        }

        System.out.println("Ticket Not Found!");
    }

    static void cancelTicket() {
        System.out.print("Enter Passenger ID: ");
        int id = sc.nextInt();

        for (Passenger p : passengers) {
            if (p.passengerId == id) {
                passengers.remove(p);
                availableSeats++;
                System.out.println("Ticket Cancelled Successfully!");
                return;
            }
        }

        System.out.println("Ticket Not Found!");
    }

    static void seatAvailability() {
        System.out.println("Available Seats: " + availableSeats);
    }

    public static void main(String[] args) {

        while (true) {
            System.out.println("\n===== Railway Reservation System =====");
            System.out.println("1. Book Ticket");
            System.out.println("2. View Reservations");
            System.out.println("3. Search Ticket");
            System.out.println("4. Cancel Ticket");
            System.out.println("5. Check Seat Availability");
            System.out.println("6. Exit");

            System.out.print("Enter Choice: ");
            int choice = sc.nextInt();

            switch (choice) {
                case 1:
                    bookTicket();
                    break;

                case 2:
                    viewReservations();
                    break;

                case 3:
                    searchTicket();
                    break;

                case 4:
                    cancelTicket();
                    break;

                case 5:
                    seatAvailability();
                    break;

                case 6:
                    System.out.println("Thank You!");
                    System.exit(0);

                default:
                    System.out.println("Invalid Choice!");
            }
        }
    }
}
